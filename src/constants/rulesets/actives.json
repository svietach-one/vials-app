          "pattern": "\\bretinyl\\s+retinoate\\b",
          "potency": "medium"
        },
        {
          "pattern": "\\b(tretinoin|adapalene|tazarotene)\\b",
          "potency": "rx"
        }
      ],
      "negativePatterns": [
        "retin(ol|al)[\\s-]*free"
      ],
      "properties": {
        "photosensitizing": true,
        "exfoliating": false,
        "irritancy": 3,
        "barrierRepair": false,
        "irritancyByPotency": {
          "low": 3,
          "medium": 3,
          "high": 4,
          "rx": 4
