# Copy this file to .env.local and fill in values.
# Never commit .env.local — it is listed in .gitignore.

# Required for AI routine suggestion + product analysis (Phase 2+).
# Leave empty until AI features are implemented.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Product corpus (Turso/libSQL embedded replica) — pull-only, read-only token.
# turso db show vials-corpus --url
# turso db tokens create vials-corpus --read-only
EXPO_PUBLIC_TURSO_URL=
EXPO_PUBLIC_TURSO_TOKEN=

# Corpus source. Set to "bundled" to open the read-only snapshot shipped at
# assets/corpus/vials_corpus.db — required for Expo Go and Intel-Mac simulator
# builds, where the libSQL native module is unavailable. Leave empty to use
# the Turso embedded replica (needs the EXPO_PUBLIC_TURSO_* vars above and a
# build with useLibSQL enabled).
EXPO_PUBLIC_CORPUS_MODE=
