# Copy this file to .env.local and fill in values.
# Never commit .env.local — it is listed in .gitignore.

# Required for AI routine suggestion + product analysis (Phase 2+).
# Leave empty until AI features are implemented.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Product corpus (Turso/libSQL embedded replica) — pull-only, read-only token.
# turso db show vials-corpus --url
# turso db tokens create vials-corpus --read-only
EXPO_PUBLIC_TURSO_URL=
EXPO_PUBLIC_TURSO_TOKEN=

# ── Community contributions (SEPARATE Turso database) ───────────────────────
# Deliberately kept apart from the corpus vars above: this is a WRITE token and
# the corpus one is READ-ONLY. Never combine them into one config object, and
# never point either at the other's database.
#
# Provision the narrowest scope Turso offers — INSERT-only, on one table:
#   turso db create vials-contributions
#   turso db shell vials-contributions < docs/database/contributions_schema.sql
#   turso db tokens create vials-contributions -p contributions:data_add --expiration 90d
#
# NOTE: EXPO_PUBLIC_* values are inlined into the app bundle and are extractable
# from a shipped build. data_add-only limits an extracted token to inserting
# rows (no reads, deletes, or schema changes) — see BLOCKERS.md for the
# residual spam risk this accepts.
#
# Requires a build with libSQL (not Expo Go, not EXPO_PUBLIC_CORPUS_MODE=bundled);
# without it the app reports sharing as unavailable rather than failing.
EXPO_PUBLIC_TURSO_CONTRIBUTIONS_URL=
EXPO_PUBLIC_TURSO_CONTRIBUTIONS_TOKEN=

# Corpus source. Set to "bundled" to open the read-only snapshot shipped at
# assets/corpus/vials_corpus.db — required for Expo Go and Intel-Mac simulator
# builds, where the libSQL native module is unavailable. Leave empty to use
# the Turso embedded replica (needs the EXPO_PUBLIC_TURSO_* vars above and a
# build with useLibSQL enabled).
EXPO_PUBLIC_CORPUS_MODE=
