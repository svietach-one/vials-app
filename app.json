{
  "expo": {
    "name": "Vials",
    "slug": "vials",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F2EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vials.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#F5F2EB"
      },
      "package": "com.vials.app"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Vials to access your photos to scan ingredient labels.",
          "cameraPermission": "Allow Vials to take photos of ingredient labels."
        }
      ]
    ]
  }
}
