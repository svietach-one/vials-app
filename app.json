{
  "expo": {
    "name": "Vials",
    "slug": "vials",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F2EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vials.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#F5F2EB"
      },
      "package": "com.vials.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Vials to access your photos to scan ingredient labels.",
          "cameraPermission": "Allow Vials to take photos of ingredient labels."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Vials to access your camera to scan product barcodes and ingredient labels."
        }
      ],
      [
        "expo-sqlite",
        {
          "useLibSQL": true
        }
      ],
      "./plugins/withLibSQLSimulatorArchFix"
    ],
    "extra": {
      "eas": {
        "projectId": "1feca79a-0cdd-4f33-af09-6a89e2621f95"
      }
    }
  }
}
